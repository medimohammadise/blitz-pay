{
  "contract": "Braintree Payment APIs",
  "version": "v1",
  "endpoints": [
    {
      "id": "braintree-client-token",
      "method": "POST",
      "path": "/v1/payments/braintree/client-token",
      "description": "Generates and returns a short-lived Braintree client token for the mobile Braintree SDK to initialise its payment UI.",
      "request": {
        "contentType": "application/json",
        "body": {}
      },
      "responses": {
        "200": {
          "description": "Client token generated successfully",
          "contentType": "application/json",
          "body": {
            "clientToken": {
              "type": "string",
              "description": "Base64-encoded JSON token for the Braintree mobile SDK.",
              "example": "eyJ2ZXJzaW9uIjoyLCJhdXRo..."
            }
          }
        },
        "500": {
          "description": "Braintree API error during token generation",
          "contentType": "application/json",
          "body": {
            "error": {
              "type": "string",
              "example": "Braintree client token generation failed"
            }
          }
        },
        "503": {
          "description": "Braintree is not configured on the server",
          "contentType": "application/json",
          "body": {
            "error": {
              "type": "string",
              "example": "Braintree not configured on server"
            }
          }
        }
      }
    },
    {
      "id": "braintree-checkout",
      "method": "POST",
      "path": "/v1/payments/braintree/checkout",
      "description": "Submits a Braintree payment nonce for immediate settlement and returns the transaction outcome.",
      "request": {
        "contentType": "application/json",
        "body": {
          "nonce": {
            "type": "string",
            "required": true,
            "description": "Single-use payment method nonce from the Braintree mobile SDK.",
            "example": "fake-valid-nonce"
          },
          "amount": {
            "type": "number",
            "required": true,
            "description": "Payment amount as a decimal (e.g. 12.50). Must be positive and finite.",
            "example": 12.50
          },
          "currency": {
            "type": "string",
            "required": false,
            "description": "ISO 4217 currency code. Defaults to 'EUR'. Used for display/logging only — Braintree settles in the merchant account's configured currency.",
            "example": "EUR"
          },
          "invoiceId": {
            "type": "string",
            "required": false,
            "description": "Optional invoice reference. Echoed in the success response for client-side reconciliation.",
            "example": "INV-2026-00042"
          }
        }
      },
      "responses": {
        "200": {
          "description": "Transaction result (success or provider-level failure). Note: HTTP 200 is returned for both 'succeeded' and 'failed' status; only server errors return 4xx/5xx.",
          "contentType": "application/json",
          "body": {
            "status": {
              "type": "string",
              "enum": ["succeeded", "failed"],
              "description": "Transaction outcome."
            },
            "transactionId": {
              "type": "string",
              "when": "status = 'succeeded'",
              "description": "Braintree transaction identifier.",
              "example": "dz89qrs4"
            },
            "amount": {
              "type": "string",
              "when": "status = 'succeeded'",
              "description": "Formatted transaction amount.",
              "example": "12.50"
            },
            "currency": {
              "type": "string",
              "when": "status = 'succeeded'",
              "description": "Echo of request currency.",
              "example": "EUR"
            },
            "invoiceId": {
              "type": "string",
              "when": "invoiceId provided in request",
              "description": "Echo of the invoice reference.",
              "example": "INV-2026-00042"
            },
            "message": {
              "type": "string",
              "when": "status = 'failed'",
              "description": "Human-readable decline reason from Braintree.",
              "example": "Do Not Honor"
            },
            "code": {
              "type": "string",
              "when": "status = 'failed' and processor code available",
              "description": "Braintree processor response code.",
              "example": "2000"
            }
          }
        },
        "400": {
          "description": "Invalid request — missing nonce, invalid amount",
          "contentType": "application/json",
          "body": {
            "error": {
              "type": "string",
              "example": "nonce and amount are required"
            }
          }
        },
        "500": {
          "description": "Server-side error during Braintree sale call",
          "contentType": "application/json",
          "body": {
            "error": {
              "type": "string",
              "example": "Braintree sale failed"
            }
          }
        },
        "503": {
          "description": "Braintree is not configured on the server",
          "contentType": "application/json",
          "body": {
            "error": {
              "type": "string",
              "example": "Braintree not configured on server"
            }
          }
        }
      },
      "security": {
        "note": "Braintree private key is never returned in any response field."
      }
    }
  ]
}
